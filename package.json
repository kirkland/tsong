{
  "name": "tsong",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "PORT=3001 concurrently -k -n server,client -c blue,magenta \"tsx watch server/index.ts\" \"vite\"",
    "dev:host": "PORT=3001 concurrently -k -n server,client -c blue,magenta \"tsx watch server/index.ts\" \"vite --host\"",
    "build": "vite build",
    "start": "tsx server/index.ts",
    "typecheck": "tsc --noEmit",
    "conservation": "tsx scripts/conservation-check.ts"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.7.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1",
    "sirv": "^2.0.4",
    "three": "^0.184.0",
    "tsx": "^4.19.2",
    "unicode-emoji-json": "^0.9.0",
    "vite": "^5.4.10",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.5.12",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}

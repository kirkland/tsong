# Copy this to .env for local dev (never commit .env).
# On the VPS, add these to /etc/tsong.env alongside DATABASE_URL.

# Google OAuth — from console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Any random string: openssl rand -hex 32
JWT_SECRET=

# Base URL the Node server is reachable at — used to build the OAuth redirect URI.
# Local dev:   http://localhost:3001
# Production:  https://tsong.life
BASE_URL=http://localhost:3001

# --- MCP Server (tsong Economy) ---
# REQUIRED: Your tsong nickname (must match your in-game name)
# TSONG_NICKNAME=YOUR_NICKNAME_HERE
# REQUIRED: The account name the MCP must resolve to (usually same as nickname)
# TSONG_EXPECT_NAME=YOUR_NICKNAME_HERE
# REQUIRED (OAuth): Your tsong_session JWT — get it from DevTools → Cookies on tsong.life
# TSONG_SESSION=YOUR_TSONG_SESSION_JWT_HERE
# Optional: Guest PID fallback (only if not using OAuth)
# TSONG_PID=YOUR_GUEST_PID_HERE
# Optional: Master enable for ALL mutating tools (set "true" to let Claude trade)
# TSONG_WRITES=false
# Optional: Log intent without sending (for testing)
# TSONG_DRY_RUN=false
# Optional: Claude's default latitude: explicit | propose | auto
# TSONG_AUTONOMY=propose
# Optional: Override the WebSocket URL (default: wss://tsong.life/ws)
# TSONG_WS_URL=wss://tsong.life/ws
# Optional: Audit log path
# TSONG_AUDIT_LOG=tools/mcp/audit.log
